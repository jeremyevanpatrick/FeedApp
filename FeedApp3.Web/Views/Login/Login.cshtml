@{
    ViewBag.Title = "Feed App 3 - Sign In";
}

<partial name="LoginHeaderPartial" />

@if (!string.IsNullOrWhiteSpace(ViewBag.ErrorMessage))
{
    <div id="errorMessage" class="contentRow ps-3 pe-3 pt-2 pb-2 text-danger" style="border-bottom:0px; border-top: 1px solid #CCC;">@ViewBag.ErrorMessage</div>
}

<partial name="LoginPartial" model="new LoginModel()" />
<partial name="RegisterPartial" model="new RegisterModel()" />

@section Scripts {
    <script>
        function toggleSection() {
            var signInSection = document.getElementById('signInSection');
            var signUpSection = document.getElementById('signUpSection');

            if (signInSection.classList.contains('open')) {
                signInSection.classList.remove('open');
                setTimeout(() => {
                    signUpSection.classList.add('open');
                    resetFormSubmit('loginForm');
                }, 250);
            } else {
                signUpSection.classList.remove('open');
                setTimeout(() => {
                    signInSection.classList.add('open');
                    resetFormAjax('registerForm', 'registerErrorMessage');
                }, 250);
            }
        }
    </script>
}
